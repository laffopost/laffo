rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shared helpers ────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isRealUser() {
      return isSignedIn()
             && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isRecentTimestamp(ts) {
      return ts is timestamp
             && ts >= request.time - duration.value(10, 's')
             && ts <= request.time + duration.value(10, 's');
    }

    // Validates the common shape of all public chat messages
    function isValidChatMessage() {
      let d = request.resource.data;
      return d.keys().hasAll(['text', 'userId', 'userName', 'timestamp'])
             && d.text is string
             && d.text.size() <= 200
             && (d.text.size() > 0 || 'gifUrl' in d)
             && request.auth.uid == d.userId
             && isRecentTimestamp(d.timestamp);
    }

    // ── Public chat rooms ─────────────────────────────────────────────

    match /chat-messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidChatMessage();
      allow delete: if isOwner(resource.data.userId);
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
    }

    match /games-chat/{messageId} {
      allow read: if isRealUser();
      allow create: if isRealUser() && isValidChatMessage();
      allow delete: if isRealUser() && isOwner(resource.data.userId);
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
    }

    match /music-chat/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidChatMessage();
      allow delete: if isOwner(resource.data.userId);
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
    }

    // ── Posts ──────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if true;
      allow create: if isRealUser()
                    && request.resource.data.uploadedBy == request.auth.uid
                    && (!('title' in request.resource.data) || request.resource.data.title.size() <= 100)
                    && (!('description' in request.resource.data) || request.resource.data.description.size() <= 500);
      allow update: if isRealUser()
                    && (request.auth.uid == resource.data.uploadedBy
                        || request.resource.data.diff(resource.data).affectedKeys()
                               .hasOnly(['reactions', 'commentCount', 'voteCounts', 'votes', 'reactors']));
      allow delete: if isSignedIn()
                    && (request.auth.uid == resource.data.uploadedBy
                        || (resource.data.endsAt != null && request.time.toMillis() > resource.data.endsAt));

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isRealUser()
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 200
                      && (request.resource.data.text.size() > 0 || 'gifUrl' in request.resource.data);
        allow update: if isRealUser()
                      && (request.auth.uid == resource.data.userId
                          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']));
        allow delete: if isRealUser()
                      && (request.auth.uid == resource.data.userId
                          || request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.uploadedBy);
      }
    }

    // ── Users ─────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // ── Direct Message Conversations ──────────────────────────────────

    match /conversations/{convoId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participants;
      }

      allow read: if isSignedIn()
                  && (resource == null || isParticipant());
      allow create: if isRealUser()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2;
      allow update: if isRealUser()
                    && (isParticipant()
                        || request.auth.uid in request.resource.data.participants);
      allow delete: if isRealUser() && isParticipant();

      match /messages/{messageId} {
        function isConvoParticipant() {
          return request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;
        }

        allow read: if isSignedIn() && isConvoParticipant();
        allow create: if isRealUser()
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 500
                      && (request.resource.data.text.size() > 0 || 'gifUrl' in request.resource.data)
                      && isConvoParticipant()
                      && isRecentTimestamp(request.resource.data.timestamp);
        allow update: if isRealUser()
                      && isConvoParticipant()
                      && (
                        // Sender can edit their own message text
                        (resource.data.senderId == request.auth.uid
                         && request.resource.data.senderId == request.auth.uid
                         && request.resource.data.text is string
                         && request.resource.data.text.size() > 0
                         && request.resource.data.text.size() <= 500)
                        ||
                        // Any participant can add/remove reactions
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
                      );
        allow delete: if isRealUser() && isConvoParticipant();
      }
    }

    // ── Notifications ─────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll(['userId', 'fromUserId', 'fromUsername', 'type', 'message', 'read', 'createdAt'])
                    && request.resource.data.type in ['like', 'comment', 'follow', 'new_post', 'mention']
                    && request.resource.data.read == false
                    && request.auth.uid == request.resource.data.fromUserId;
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── Follows ───────────────────────────────────────────────────────

    match /follows/{followId} {
      allow read: if true;
      allow create: if isRealUser()
                    && request.resource.data.keys().hasAll(['followerId', 'followingId', 'createdAt'])
                    && request.auth.uid == request.resource.data.followerId
                    && request.auth.uid != request.resource.data.followingId;
      allow delete: if isOwner(resource.data.followerId);
      allow update: if false;
    }

    // ── Bookmarks ─────────────────────────────────────────────────────

    match /bookmarks/{bookmarkId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isRealUser()
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.keys().hasAll(['userId', 'postId', 'createdAt']);
      allow delete: if isOwner(resource.data.userId);
      allow update: if false;
    }

    // ── Game scores ───────────────────────────────────────────────────

    match /gameScores/{scoreId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll(['game', 'score', 'userId', 'username', 'timestamp'])
                    && request.resource.data.game is string
                    && request.resource.data.score is number
                    && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // ── User-submitted jokes ─────────────────────────────────────────
    match /jokes/{jokeId} {
      allow read: if true;
      allow create: if isRealUser()
                    && request.resource.data.keys().hasAll(['setup', 'delivery', 'authorUid', 'authorName'])
                    && request.resource.data.setup is string
                    && request.resource.data.delivery is string
                    && request.auth.uid == request.resource.data.authorUid;
      // Anyone signed in can update score (upvote/downvote)
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['score', 'upvotes', 'downvotes']);
      // Only author can delete
      allow delete: if isRealUser() && resource.data.authorUid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isRealUser()
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 500;
        allow delete: if isRealUser() && resource.data.userId == request.auth.uid;
      }
    }

    // ── Feedback & Ideas ──────────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if isRealUser()
                    && request.resource.data.keys().hasAll(['title', 'category', 'userId', 'username', 'votes', 'voteCount', 'status', 'createdAt'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 120
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.voteCount == 0
                    && request.resource.data.status == 'open';
      // Anyone signed in can vote (votes array + voteCount)
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['votes', 'voteCount']);
      // Only author can delete
      allow delete: if isRealUser() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isRealUser()
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 500;
        allow delete: if isRealUser() && resource.data.userId == request.auth.uid;
      }
    }

    // ── Joke votes (Best category) ───────────────────────────────────
    match /jokeVotes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // ── Default deny ──────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
